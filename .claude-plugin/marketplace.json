{
  "name": "kobana-agent-skills",
  "owner": {
    "name": "Kobana",
    "email": "contato@kobana.com.br"
  },
  "metadata": {
    "description": "Kobana skills para automação financeira e processamento de documentos",
    "version": "1.1.0",
    "license": "MIT"
  },
  "plugins": [
    {
      "name": "kobana-agent-skills",
      "description": "Kobana financial automation skills for Pix charges, transfers, and payments via MCP servers and REST API",
      "source": "./",
      "skills": [
        "./skills/charge-pix",
        "./skills/transfer-pix",
        "./skills/payment-pix"
      ],
      "mcpServers": {
        "kobana-charge": {
          "command": "npx",
          "args": ["-y", "kobana-mcp-charge"],
          "env": {
            "KOBANA_ACCESS_TOKEN": "${KOBANA_ACCESS_TOKEN}",
            "KOBANA_API_URL": "${KOBANA_API_URL}"
          }
        },
        "kobana-transfer": {
          "command": "npx",
          "args": ["-y", "kobana-mcp-transfer"],
          "env": {
            "KOBANA_ACCESS_TOKEN": "${KOBANA_ACCESS_TOKEN}",
            "KOBANA_API_URL": "${KOBANA_API_URL}"
          }
        },
        "kobana-payment": {
          "command": "npx",
          "args": ["-y", "kobana-mcp-payment"],
          "env": {
            "KOBANA_ACCESS_TOKEN": "${KOBANA_ACCESS_TOKEN}",
            "KOBANA_API_URL": "${KOBANA_API_URL}"
          }
        },
        "kobana-financial": {
          "command": "npx",
          "args": ["-y", "kobana-mcp-financial"],
          "env": {
            "KOBANA_ACCESS_TOKEN": "${KOBANA_ACCESS_TOKEN}",
            "KOBANA_API_URL": "${KOBANA_API_URL}"
          }
        },
        "kobana-admin": {
          "command": "npx",
          "args": ["-y", "kobana-mcp-admin"],
          "env": {
            "KOBANA_ACCESS_TOKEN": "${KOBANA_ACCESS_TOKEN}",
            "KOBANA_API_URL": "${KOBANA_API_URL}"
          }
        },
        "kobana-data": {
          "command": "npx",
          "args": ["-y", "kobana-mcp-data"],
          "env": {
            "KOBANA_ACCESS_TOKEN": "${KOBANA_ACCESS_TOKEN}",
            "KOBANA_API_URL": "${KOBANA_API_URL}"
          }
        },
        "kobana-edi": {
          "command": "npx",
          "args": ["-y", "kobana-mcp-edi"],
          "env": {
            "KOBANA_ACCESS_TOKEN": "${KOBANA_ACCESS_TOKEN}",
            "KOBANA_API_URL": "${KOBANA_API_URL}"
          }
        }
      }
    }
  ]
}
